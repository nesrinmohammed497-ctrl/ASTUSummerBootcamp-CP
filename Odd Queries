t = int(input())
for _ in range(t):
    n, q = map(int, input().split())
    a = list(map(int, input().split()))
    prefix = [0] * (n + 1)
    for i in range(n):
        prefix[i + 1] = prefix[i] + a[i]
    total = prefix[n]
    for _ in range(q):
        l, r, k = map(int, input().split())
        segment = prefix[r] - prefix[l - 1]
        length = r - l + 1
        new_sum = total - segment + length * k
        if new_sum % 2:
            print("YES")
        else:
            print("NO")
