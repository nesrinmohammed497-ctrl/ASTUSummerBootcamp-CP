for _ in range(t):
    n, m, k = map(int, input().split())
    a = sorted(input())
    b = sorted(input())
    i = 0
    j = 0
    cnta = 0
    cntb = 0
    ans = ""
    while i < n and j < m:
        if (a[i] < b[j] and cnta < k) or cntb == k:
